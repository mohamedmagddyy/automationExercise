<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="AutomationExercise Suite" verbose="2">

    <!-- Register Test Listener -->
    <listeners>
        <listener class-name="org.example.listeners.TestListener"/>
    </listeners>

    <!-- Chrome Tests -->
    <test name="Chrome Tests" preserve-order="true">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="org.example.tests.SignupLoginTests"/>
            <class name="org.example.tests.HomeTests"/>
            <class name="org.example.tests.ProductsTests"/>
            <class name="org.example.tests.CartTests"/>
        </classes>
    </test>

    <!-- Edge Tests -->
    <test name="Edge Tests" preserve-order="true">
        <parameter name="browser" value="edge"/>
        <classes>
            <class name="org.example.tests.SignupLoginTests"/>
            <class name="org.example.tests.HomeTests"/>
            <class name="org.example.tests.ProductsTests"/>
            <class name="org.example.tests.CartTests"/>
        </classes>
    </test>

</suite>
